# Supabase project URL (Settings → API). Hostinger may inject this automatically.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Server-only service role key (Settings → API). Never expose as NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=

# Optional: Hostinger Supabase wizard may also inject the anon key.
SUPABASE_ANON_KEY=

# Auth.js and Google OAuth.
AUTH_SECRET=
AUTH_TRUST_HOST=true
AUTH_URL=https://ilovebiodata.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Razorpay.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=
