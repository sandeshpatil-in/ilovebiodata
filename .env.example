# Supabase project URL (Settings → API).
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Server-only service role key (Settings → API). Never expose as NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=

# Publishable/anon key (Supabase may label this publishable or anon).
SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Auth.js and Google OAuth.
# Local: http://localhost:3000
# Live: https://ilovebiodata.com
AUTH_SECRET=
AUTH_TRUST_HOST=true
AUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Razorpay (optional for local UI testing).
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=
